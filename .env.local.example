# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (AI Assistant)
ANTHROPIC_API_KEY=sk-ant-your-key

# Anthropic Managed Agents (Sessions API - Beta)
# Create an agent at https://console.anthropic.com/agents
# Both vars required to use Sessions API — omit to fall back to standard Messages API
ANTHROPIC_AGENT_ID=agent_xxx
ANTHROPIC_ENVIRONMENT_ID=env_xxx

# Google Drive Integration (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=tenir.app
